<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/main_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/main_title"
            android:textAppearance="?attr/textAppearanceHeadline4" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_button"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:minHeight="48dp"
            android:text="@string/settings" />

        <TextView
            android:id="@+id/capture_section_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/capture_section_title"
            android:textAppearance="?attr/textAppearanceHeadline6" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/capture_debug_explanation"
            android:textAppearance="?attr/textAppearanceBody2" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ProgressBar
                android:id="@+id/capture_progress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/capture_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/capture_status_inactive"
                android:textAppearance="?attr/textAppearanceBody1" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/start_capture_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:minHeight="48dp"
            android:text="@string/start_capture" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/capture_screenshot_button"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:enabled="false"
            android:minHeight="48dp"
            android:text="@string/capture_screenshot" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/stop_capture_button"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:enabled="false"
            android:minHeight="48dp"
            android:text="@string/stop_capture" />

        <ImageView
            android:id="@+id/capture_preview"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="20dp"
            android:background="@color/capture_preview_background"
            android:contentDescription="@string/capture_preview_description"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <TextView
            android:id="@+id/ocr_box_section_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/ocr_box_section_title"
            android:textAppearance="?attr/textAppearanceHeadline6" />

        <TextView
            android:id="@+id/ocr_box_coordinates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/ocr_box_coordinates_default"
            android:textAppearance="?attr/textAppearanceBody2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/reset_ocr_box_button"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="48dp"
            android:text="@string/reset_ocr_box" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/preview_ocr_crop_button"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:enabled="false"
            android:minHeight="48dp"
            android:text="@string/preview_ocr_crop" />

        <ImageView
            android:id="@+id/ocr_crop_preview"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginTop="16dp"
            android:background="@color/capture_preview_background"
            android:contentDescription="@string/ocr_crop_preview_description"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <TextView
            android:id="@+id/overlay_section_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/overlay_section_title"
            android:textAppearance="?attr/textAppearanceHeadline6" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/overlay_debug_explanation"
            android:textAppearance="?attr/textAppearanceBody2" />

        <TextView
            android:id="@+id/overlay_permission_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/overlay_permission_missing"
            android:textAppearance="?attr/textAppearanceBody1" />

        <TextView
            android:id="@+id/overlay_service_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/overlay_service_stopped"
            android:textAppearance="?attr/textAppearanceBody1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/request_overlay_permission_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:minHeight="48dp"
            android:text="@string/request_overlay_permission" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/start_overlay_button"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:enabled="false"
            android:minHeight="48dp"
            android:text="@string/start_overlay" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/stop_overlay_button"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:enabled="false"
            android:minHeight="48dp"
            android:text="@string/stop_overlay" />

    </LinearLayout>

</ScrollView>
